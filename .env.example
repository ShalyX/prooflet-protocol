# Useful Waiting local/test configuration.
# Copy this file to .env, fill only the values you need, and NEVER commit real keys.
# Never expose treasury or API keys in frontend code, logs, uploads, or API responses.

# API and database
API_PORT=8787
UWP_DB_PATH=data/useful-waiting.sqlite
PROOFLET_STORAGE_DURABILITY=local
PROOFLET_PERSISTENT_MOUNT_PATH=
PROOFLET_DURABLE_STORAGE_REQUIRED=false
PROOFLET_SEED_DEMO_DATA=false
PROOFLET_ALLOWED_ORIGINS=https://prooflet.xyz,https://www.prooflet.xyz,http://127.0.0.1:5173
USEFUL_WAITING_API_URL=http://127.0.0.1:8787

# Autonomous agent
AGENT_ID=agent_lynx
AGENT_API_KEY=
WORKER_CAPABILITIES=link_verification
POLL_INTERVAL_MS=5000
WORKER_FETCH_TIMEOUT_MS=20000

# Issuer
ISSUER_ID=useful_waiting_protocol
ISSUER_API_KEY=
LINK_URL=https://docs.arc.network
LINK_REWARD_AMOUNT=0.001
JOB_ID=

# Subjective adjudication. GenLayer is opt-in and keys remain server-side.
ADJUDICATOR_API_KEY=
ADJUDICATION_MODE=genlayer
GENLAYER_NETWORK=testnet-bradbury
GENLAYER_CONTRACT_ADDRESS=0x132fF41207B4E94172A0184A738a51EF39aEFbF6
GENLAYER_PRIVATE_KEY=
GENLAYER_RPC_OR_API_URL=
GENLAYER_REQUEST_TIMEOUT_MS=15000
GENLAYER_POLL_INTERVAL_MS=5000
GENLAYER_MAX_WAIT_MS=120000

# Arc Testnet only
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
TREASURY_PRIVATE_KEY=
TREASURY_ADDRESS=

# Circle Gateway x402 access fees (must differ from agent payer / treasury when agents pay from treasury)
# Circle rejects self_transfer when payTo === from.
CIRCLE_GATEWAY_SELLER_ADDRESS=
CIRCLE_GATEWAY_API_URL=https://gateway-api-testnet.circle.com

# Circle Developer Controlled Wallets (optional — for wallet creation + USDC transfers)
# Create an API key at https://developer.circle.com/ -> API Keys
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_TREASURY_WALLET_ID=


# Settlement is dry-run unless explicitly changed and confirmed.
SETTLEMENT_MODE=dry-run
SETTLEMENT_INTERVAL_MS=60000
CONFIRM_ARC_TESTNET_USDC_SEND=false
RECIPIENTS_FILE=settlement/agent-addresses.json
BATCH_FILE=work/settlement-batch.json
SETTLEMENT_STATE_FILE=settlement/settlement-state.json
REMOTE_SETTLEMENT_BATCH_ID=
REMOTE_SETTLEMENT_PROOF_IDS=

# Legacy one-off sender compatibility. Prefer TREASURY_PRIVATE_KEY and the daemon.
PRIVATE_KEY=
WORKER_ADDRESS=
USDC_AMOUNT=0.01

# Prooflet Escrow V1 (deployed Arc Testnet demo escrow)
ESCROW_CONTRACT_ADDRESS=0xb3397ce196ebf553b8e951abaf75c18785c7e69a
SETTLEMENT_OPERATOR_PRIVATE_KEY=
ESCROW_DEPLOYER_PRIVATE_KEY=
ESCROW_OPERATOR_ADDRESS=

# Circle Nanopayment-style access fee (Arc Testnet USDC event-scan verification)
# Agents pay a tiny fee before claiming jobs. This is not full Circle Gateway merchant/session integration.
NANOPAYMENT_ENABLED=true
NANOPAYMENT_ACCESS_FEE=0.000001
