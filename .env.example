# Useful Waiting local/test configuration.
# Copy this file to .env, fill only the values you need, and NEVER commit real keys.
# Never expose treasury or API keys in frontend code, logs, uploads, or API responses.

# API and database
API_PORT=8787
UWP_DB_PATH=data/useful-waiting.sqlite
USEFUL_WAITING_API_URL=http://127.0.0.1:8787

# Autonomous agent
AGENT_ID=agent_lynx
AGENT_API_KEY=
WORKER_CAPABILITIES=link_verification
POLL_INTERVAL_MS=5000
WORKER_FETCH_TIMEOUT_MS=20000

# Issuer
ISSUER_ID=useful_waiting_protocol
ISSUER_API_KEY=
LINK_URL=https://docs.arc.network
LINK_REWARD_AMOUNT=0.001
JOB_ID=

# Subjective adjudication. GenLayer is opt-in and keys remain server-side.
ADJUDICATOR_API_KEY=
ADJUDICATION_MODE=manual
GENLAYER_NETWORK=localnet
GENLAYER_CONTRACT_ADDRESS=
GENLAYER_PRIVATE_KEY=
GENLAYER_RPC_OR_API_URL=
GENLAYER_REQUEST_TIMEOUT_MS=15000
GENLAYER_POLL_INTERVAL_MS=5000
GENLAYER_MAX_WAIT_MS=120000

# Arc Testnet only
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
TREASURY_PRIVATE_KEY=
TREASURY_ADDRESS=

# Settlement is dry-run unless explicitly changed and confirmed.
SETTLEMENT_MODE=dry-run
SETTLEMENT_INTERVAL_MS=60000
CONFIRM_ARC_TESTNET_USDC_SEND=false
RECIPIENTS_FILE=settlement/agent-addresses.json
BATCH_FILE=work/settlement-batch.json
SETTLEMENT_STATE_FILE=settlement/settlement-state.json
REMOTE_SETTLEMENT_BATCH_ID=
REMOTE_SETTLEMENT_PROOF_IDS=

# Legacy one-off sender compatibility. Prefer TREASURY_PRIVATE_KEY and the daemon.
PRIVATE_KEY=
WORKER_ADDRESS=
USDC_AMOUNT=0.01
