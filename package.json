{
  "name": "useful-waiting",
  "description": "Prooflet: tiny agent jobs, verified by proof, paid in USDC.",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "api": "node --no-warnings server/api.mjs",
    "db": "node --no-warnings scripts/db.mjs",
    "db:reset": "node --no-warnings scripts/db.mjs --reset",
    "db:export": "node --no-warnings scripts/export-settlement-batch.mjs",
    "db:migrate": "node --no-warnings scripts/db-migrate.mjs",
    "reputation:rebuild": "node --no-warnings scripts/rebuild-reputation.mjs",
    "reputation:check": "node --no-warnings scripts/reputation-acceptance.mjs",
    "settlement:check": "node --no-warnings scripts/check-settlement.mjs",
    "sdk:test": "node --no-warnings scripts/sdk-acceptance.mjs",
    "sdk:pack": "npm pack --dry-run --workspace @useful-waiting/sdk-core && npm pack --dry-run --workspace @useful-waiting/agent-sdk && npm pack --dry-run --workspace @useful-waiting/issuer-sdk",
    "adjudication:check": "node --no-warnings scripts/adjudication-acceptance.mjs",
    "genlayer:check": "node --no-warnings --env-file-if-exists=.env scripts/genlayer-check.mjs",
    "genlayer:demo": "node --no-warnings --env-file-if-exists=.env scripts/genlayer-demo.mjs",
    "demo:seed": "node --no-warnings --env-file-if-exists=.env scripts/genlayer-demo.mjs",
    "genlayer:mock-check": "node --no-warnings scripts/genlayer-acceptance.mjs",
    "adjudication:genlayer:check": "node --no-warnings scripts/genlayer-acceptance.mjs",
    "genlayer:deploy": "node --no-warnings --env-file-if-exists=.env scripts/genlayer-deploy.mjs",
    "genlayer:submit-fixture": "node --no-warnings --env-file-if-exists=.env scripts/genlayer-submit-fixture.mjs",
    "genlayer:poll-decision": "node --no-warnings --env-file-if-exists=.env scripts/genlayer-poll-decision.mjs",
    "uploads:check": "node --no-warnings scripts/uploads-acceptance.mjs",
    "workbench:check": "npm run build",
    "api:check": "node --no-warnings scripts/api-acceptance.mjs",
    "agent:link": "node --no-warnings --env-file-if-exists=.env workers/link-sentinel.mjs",
    "agent:check": "node --no-warnings --env-file-if-exists=.env workers/link-sentinel.mjs --check",
    "agent:register": "node --no-warnings --env-file-if-exists=.env scripts/register-agent.mjs",
    "job:create-link": "node --no-warnings --env-file-if-exists=.env scripts/create-link-job.mjs",
    "job:create-link:check": "node --no-warnings scripts/create-link-job-acceptance.mjs",
    "submission:check": "npm run sdk:test && npm run reputation:check && npm run adjudication:check && npm run genlayer:mock-check && npm run uploads:check && npm run settlement:check && npm run api:check && npm run job:create-link:check && npm run build",
    "settlement:daemon": "node --no-warnings --env-file-if-exists=.env workers/settlement-daemon.mjs",
    "settlement:daemon:dry-run": "node --no-warnings --env-file-if-exists=.env workers/settlement-daemon.mjs --mode=dry-run",
    "settlement:daemon:execute": "node --no-warnings --env-file-if-exists=.env workers/settlement-daemon.mjs --mode=execute",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "arc:check": "node --no-warnings --env-file=.env scripts/arc-check.mjs",
    "arc:settle": "node --no-warnings --env-file=.env scripts/arc-settle-batch.mjs",
    "settle:arc": "node --env-file=.env scripts/settle-arc.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "express": "^5.2.1",
    "genlayer-js": "^1.1.8",
    "lucide-react": "^0.468.0",
    "ox": "^0.14.29",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "viem": "^2.53.1",
    "vite": "^6.0.7"
  },
  "overrides": {
    "ws": "8.21.0"
  }
}
